{
  "name": "yyc3-qz-merchant-management-system",
  "version": "0.1.0",
  "description": "YYC³-QZ-Merchant-Management-System: AI-Powered KTV Business Management Platform",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "next build",
    "build:static": "mv app/api app/_api_tmp && mv middleware.ts middleware.ts.tmp && BUILD_MODE=static NODE_ENV=production next build; mv app/_api_tmp app/api; mv middleware.ts.tmp middleware.ts",
    "clean": "rm -rf .next node_modules/.cache tsconfig.tsbuildinfo",
    "clean:all": "rm -rf .next node_modules/.cache tsconfig.tsbuildinfo node_modules && pnpm install",
    "dev": "next dev -p 5001",
    "lint": "eslint .",
    "rebuild": "pnpm run clean && pnpm run build",
    "start": "next start",
    "test": "jest --watch",
    "test:all": "ts-node scripts/run-tests.ts",
    "test:ci": "jest --ci",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:integration": "jest --testMatch='**/__tests__/integration/**/*.test.ts'",
    "test:performance": "bash performance/run-performance-tests.sh all",
    "test:performance:api": "k6 run performance/api-performance.js",
    "test:performance:db": "k6 run performance/db-performance.js",
    "test:performance:concurrent": "k6 run performance/concurrent-users.js",
    "test:performance:cache": "k6 run performance/cache-performance.js",
    "test:performance:payment": "k6 run performance/payment-stress.js",
    "test:performance:upload": "k6 run performance/upload-performance.js",
    "test:performance:websocket": "k6 run performance/websocket-test.js",
    "test:performance:stress": "k6 run performance/comprehensive-stress.js",
    "test:run": "ts-node scripts/run-tests.ts",
    "test:security": "playwright test tests/security",
    "test:security:node-forge": "jest --testMatch='**/__tests__/security/*node-forge*.test.ts'",
    "test:unit": "jest --testMatch='**/__tests__/**/*.test.ts' --testPathIgnorePatterns='/integration/'",
    "validate:env": "ts-node utils/env.validator.ts",
    "security:check-node-forge": "node scripts/check-node-forge-vulnerability.js",
    "security:audit": "pnpm audit && pnpm run security:check-node-forge",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
