# ==========================================
# YYC3 Admin System - 环境变量配置模板
# ==========================================
# 使用说明: 复制此文件为 .env.local 并填入实际值
# 安全提示: 绝不将真实密钥提交到版本控制
# ==========================================

# ==========================================
# 1. PostgreSQL 数据库 (必需)
# ==========================================
# 方式一: 连接字符串 (推荐)
# DATABASE_URL=postgresql://user:password@localhost:5432/yyc3_yy

# 方式二: 分开配置
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_pg_password
PG_DATABASE=yyc3_yy

# ==========================================
# 2. Redis 缓存 (推荐)
# ==========================================
REDIS_URL=redis://localhost:6379
# 生产环境建议启用密码认证
# REDIS_PASSWORD=your_redis_password

# ==========================================
# 3. JWT 认证 (必需)
# ==========================================
# 生成方式: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_min_32_chars

# ==========================================
# 4. CORS 安全 (生产必需)
# ==========================================
# 允许的来源域名，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5001

# ==========================================
# 5. 应用配置
# ==========================================
NODE_ENV=development
NEXT_PUBLIC_API_BASE_URL=/api

# ==========================================
# 6. 功能开关 (开发调试)
# ==========================================
ENABLE_MOCK_DATA=true
